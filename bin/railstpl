#!/usr/bin/env bash

main() {
  local base_path=$HOME/railstpl/src
  local tpl="$1"
  local path1=$base_path/$tpl.rb
  local is_rails=$(is_rails_dir)
  if [ "$is_rails" != "true" ]; then
    echo " error: must be inside a rails dir"
    exit 1
  fi

  if [ -z $tpl ]; then
    echo " usage: railstpl <tpl>"
  elif [ "$tpl" == "list" ]; then
    list_scripts
  elif [ -f $path1 ]; then
    rails app:template LOCATION=$path1
  else
    echo " not found: $path1"
  fi
}

is_rails_dir() {
  local file="$PWD/app/controllers/application_controller.rb"
  if [ -f $file ]; then
    echo true
  else
    echo false
  fi
}

list_scripts() {
  tree --noreport $base_path
  # for f in $(ls $base_path/**/*.rb); do
  #   echo $f
  # done
}

main "$@"