<% navigation.with_section(data: { testid: "sidebar" }) do |section| %>
  <% section.with_item(
    url: root_path,
    label: "Home",
    icon: "HomeMajor",
    selected: true,
  ) %>
  <% section.with_item(
    url: tenants_path,
    label: t("shared.navbar.tenants"),
    icon: "FolderMajor",
  ) %>
  <% section.with_item(
    url: avo_path,
    label: t("shared.navbar.avo"),
    icon: "FolderMajor",
  ) %>
  <% section.with_item(
    url: "/flipper/features",
    label: t("shared.navbar.flipper"),
    icon: "FolderMajor",
  ) %>

  <% navigation.with_section(separator: true) do |section| %>
    <% if Rails.env.development? %>
      <% section.with_item(
        url: notes_path,
        label: t("shared.navbar.notes"),
        icon: "NoteMajor",
        selected: match_current_path?(notes_path)
      ) %>
    <% end %>

    <% section.with_item(
      url: custom_logout_path,
      label: t("shared.navbar.log_out"),
      icon: "ExitMajor"
    ) %>
  <% end %> 
<% end %>
