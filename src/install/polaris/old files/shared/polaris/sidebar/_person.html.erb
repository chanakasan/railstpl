<% navigation.with_section(data: { testid: "sidebar" }) do |section| %>
  <% section.with_item(
    url: root_path,
    label: t("shared.navbar.home"),
    icon: "HomeMajor",
    selected: match_current_path?(root_path)
  ) %>

  <% if policy(Client).index? %>
    <% section.with_item(
      url: clients_path,
      label: t("shared.navbar.clients"),
      icon: "FolderMajor",
      selected: match_current_path?(clients_path)
    ) %>
  <% end%>

  <% if policy(Item).index? %>
    <% section.with_item(
      url: items_path,
      label: t("shared.navbar.items"),
      icon: "FolderMajor",
      selected: match_current_path?(items_path)
    ) %>
  <% end%>

  <% if policy(Person).index? %>
    <% section.with_item(
      url: people_path,
      label: t("shared.navbar.people"),
      icon: "FolderMajor",
      selected: match_current_path?(people_path)
    ) %>
  <% end%>

  <% if current_person.resource.present? %>
    <% weekly_resource_nav_path = weekly_resource_path(current_person.resource) %>
    <% section.with_item(
      url: weekly_resource_nav_path,
      label: t("shared.navbar.my_schedule"),
      icon: "FolderMajor",
      selected: match_current_path?(weekly_resource_nav_path)
    ) %>
  <% end %>

  <% navigation.with_section(separator: true) do |section| %>
    <% section.with_item(
      url: settings_path,
      label: t("shared.navbar.settings"),
      icon: "SettingsMinor",
      selected: match_current_path?(settings_path)
    ) %>

    <% section.with_item(
      url: custom_logout_path,
      label: t("shared.navbar.log_out"),
      icon: "ExitMajor"
    ) %>
  <% end %> 
<% end %>
